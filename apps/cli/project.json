{
  "name": "cli",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/cli/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bunx nest build cli",
        "cwd": "{workspaceRoot}"
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bunx nest start cli",
        "cwd": "{workspaceRoot}"
      }
    },
    "start:dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bunx nest start cli --watch",
        "cwd": "{workspaceRoot}"
      }
    }
  }
}
