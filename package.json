{
  "name": "@ever-jobs/root",
  "version": "0.1.0",
  "private": true,
  "description": "Ever Jobs — NestJS monorepo for multi-source job scraping",
  "license": "MIT",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npx nx run-many --target=build --all",
    "start:dev": "npx nx run api:start:dev",
    "cli": "npx ts-node -r tsconfig-paths/register apps/cli/src/main.ts",
    "lint": "npx nx run-many --target=lint --all",
    "test": "jest",
    "test:e2e": "jest --testPathPattern e2e-spec"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.0",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^10.4.0",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/swagger": "^7.4.0",
    "@nestjs/throttler": "^6.5.0",
    "@upwork/node-upwork-oauth2": "^2.3.0",
    "axios": "^1.7.0",
    "cheerio": "^1.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^17.2.4",
    "exa-js": "^2.3.0",
    "https-proxy-agent": "^7.0.0",
    "nest-commander": "^3.20.1",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "socks-proxy-agent": "^8.0.0",
    "turndown": "^7.2.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.0",
    "@nestjs/schematics": "^10.1.0",
    "@nestjs/testing": "^10.4.22",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.14.0",
    "@types/supertest": "^6.0.3",
    "@types/turndown": "^5.0.5",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "jest": "^30.2.0",
    "nx": "^19.0.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.0"
  }
}
