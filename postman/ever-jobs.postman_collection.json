    {
      "name": "GraphQL",
      "item": [
        {
          "name": "POST /graphql - searchJobs",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Sin errores GraphQL', function () {",
                  "  var body = pm.response.json();",
                  "  pm.expect(body.errors).to.eql(undefined);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "x-api-key",
                "value": "{{apiKey}}",
                "type": "text"
              }
            ],
            "description": "Busqueda via GraphQL.\n\nInput soportado por `searchJobs(input)`:\n- `siteType: [Site]`\n- `searchTerm: String!`\n- `location: String`\n- `resultsWanted: Int`\n- `country: String`\n- `distance: Int`\n- `companySlug: String`\n- `descriptionFormat: String`\n\nLa API GraphQL expone este endpoint en `POST /graphql`.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"query SearchJobs($input: SearchJobsInput!) { searchJobs(input: $input) { count cached jobs { id site title companyName jobUrl description datePosted isRemote companyUrl logoUrl location { country city state } compensation { minAmount maxAmount currency interval } jobType emails } } }\",\n  \"variables\": {\n    \"input\": {\n      \"searchTerm\": \"{{searchTerm}}\",\n      \"location\": \"{{location}}\",\n      \"resultsWanted\": {{resultsWanted}},\n      \"country\": \"{{country}}\",\n      \"descriptionFormat\": \"markdown\",\n      \"siteType\": [\"GOOGLE\", \"INDEED\"]\n    }\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/graphql",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "graphql"
              ]
            }
          }
        },
        {
          "name": "POST /graphql - listSources",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Retorna listado de fuentes', function () {",
                  "  var body = pm.response.json();",
                  "  pm.expect(body.errors).to.eql(undefined);",
                  "  pm.expect(body.data.listSources).to.have.property('total');",
                  "  pm.expect(body.data.listSources).to.have.property('sources');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "x-api-key",
                "value": "{{apiKey}}",
                "type": "text"
              }
            ],
            "description": "Devuelve el enum completo de fuentes soportadas por el proyecto. Es la forma mas util para descubrir todos los valores validos de `siteType` en tiempo real.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"query { listSources { total sources { name value } } }\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/graphql",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "graphql"
              ]
            }
          }
        }
      ]
    }
  ]
