        {
          "name": "POST /api/jobs/search - ATS by companySlug",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200 o 201', function () {",
                  "  pm.expect([200, 201]).to.include(pm.response.code);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "x-api-key",
                "value": "{{apiKey}}",
                "type": "text"
              }
            ],
            "description": "Ejemplo para scrapers ATS que requieren `companySlug`.\n\nEjemplo publico:\n- `siteType: [\"greenhouse\"]`\n- `companySlug: \"stripe\"`\n\nEjemplo autenticado opcional:\n- `auth.greenhouse.apiKey`\n- `auth.workable.accessToken` y `auth.workable.subdomain`\n\nAjusta el body segun la fuente ATS que quieras probar.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"searchTerm\": \"{{searchTerm}}\",\n  \"siteType\": [\"{{atsSite}}\"],\n  \"companySlug\": \"{{companySlug}}\",\n  \"resultsWanted\": {{resultsWanted}},\n  \"descriptionFormat\": \"markdown\",\n  \"auth\": {\n    \"greenhouse\": {\n      \"apiKey\": \"{{greenhouseApiKey}}\"\n    },\n    \"workable\": {\n      \"accessToken\": \"{{workableAccessToken}}\",\n      \"subdomain\": \"{{workableSubdomain}}\"\n    }\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/jobs/search",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "jobs",
                "search"
              ]
            }
          }
        },
        {
          "name": "POST /api/jobs/analyze",
          "event": [
            {
