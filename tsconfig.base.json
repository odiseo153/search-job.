      "@ever-jobs/source-company-apple": ["packages/source-company-apple/src/index.ts"],
      "@ever-jobs/source-company-microsoft": ["packages/source-company-microsoft/src/index.ts"],
      "@ever-jobs/source-company-nvidia": ["packages/source-company-nvidia/src/index.ts"],
