      "@ever-jobs/source-google": ["packages/source-google/src/index.ts"],
      "@ever-jobs/source-bayt": ["packages/source-bayt/src/index.ts"],
      "@ever-jobs/source-naukri": ["packages/source-naukri/src/index.ts"],
      "@ever-jobs/source-bdjobs": ["packages/source-bdjobs/src/index.ts"],
      "@ever-jobs/source-internshala": ["packages/source-internshala/src/index.ts"],
      "@ever-jobs/analytics": ["packages/analytics/src/index.ts"],
      "@ever-jobs/source-exa": ["packages/source-exa/src/index.ts"],
      "@ever-jobs/source-upwork": ["packages/source-upwork/src/index.ts"],
      "@ever-jobs/source-ats-ashby": ["packages/source-ats-ashby/src/index.ts"],
      "@ever-jobs/source-ats-greenhouse": ["packages/source-ats-greenhouse/src/index.ts"],
      "@ever-jobs/source-ats-lever": ["packages/source-ats-lever/src/index.ts"],
      "@ever-jobs/source-ats-workable": ["packages/source-ats-workable/src/index.ts"],
